-           ruleFiresFunction != NULL;
-           ruleFiresFunction = ruleFiresFunction->next)
-        { (*ruleFiresFunction->func)(theEnv,NULL,ruleFiresFunction->context); }
-     }
+   for (runFiresFunction = EngineData(theEnv)->ListOfAfterRunFiresFunctions;
+         runFiresFunction != NULL;
+         runFiresFunction = runFiresFunction->next)
