+
+/**********************************************/
+/* AddAfterRunFiresFunction: Adds a function  */
+/*   to the ListOfAfterRunFiresFunctions.     */
+/**********************************************/
+bool AddAfterRunFiresFunction(
+  Environment *theEnv,
+  const char *name,
+  RunFiredFunction *functionPtr,
+  int priority,
+  void *context)
+  {
+   EngineData(theEnv)->ListOfAfterRunFiresFunctions =
+      AddRunFiredFunctionToCallList(theEnv,name,priority,functionPtr,
+                                    EngineData(theEnv)->ListOfAfterRunFiresFunctions,
+                                    context);
+   return true;
+  }
+
+/***********************************************/
+/* AddBeforeRunFiresFunction: Adds a function  */
+/*   to the ListOfBeforeRunFiresFunctions.     */
+/***********************************************/
+bool AddBeforeRunFiresFunction(
+  Environment *theEnv,
+  const char *name,
+  RunFiredFunction *functionPtr,
+  int priority,
+  void *context)
+  {
+   EngineData(theEnv)->ListOfBeforeRunFiresFunctions =
+      AddRunFiredFunctionToCallList(theEnv,name,priority,functionPtr,
+                                    EngineData(theEnv)->ListOfBeforeRunFiresFunctions,
+                                    context);
+   return true;
+  }
+
+/****************************************************/
+/* RemoveAfterRunFiresFunction: Removes a function  */
+/*   from the ListOfAfterRunFiresFunctions.         */
+/****************************************************/
+bool RemoveAfterRunFiresFunction(
+  Environment *theEnv,
+  const char *name)
+  {
+   bool found;
+
+   EngineData(theEnv)->ListOfAfterRunFiresFunctions =
+      RemoveRunFiredFunctionFromCallList(theEnv,name,
+                                         EngineData(theEnv)->ListOfAfterRunFiresFunctions,
+                                         &found);
+
+   return found;
+  }
+
+/*****************************************************/
+/* RemoveBeforeRunFiresFunction: Removes a function  */
+/*   from the ListOfBeforeRunFiresFunctions.         */
+/*****************************************************/
+bool RemoveBeforeRunFiresFunction(
+  Environment *theEnv,
+  const char *name)
+  {
+   bool found;
+
+   EngineData(theEnv)->ListOfBeforeRunFiresFunctions =
+      RemoveRunFiredFunctionFromCallList(theEnv,name,
+                                         EngineData(theEnv)->ListOfBeforeRunFiresFunctions,
+                                         &found);
+
+   return found;
+  }
+
+/***************************************************/
+/* AddRunFiredFunctionToCallList: Adds a function */
+/*   to a run fired function list.                */
+/***************************************************/
+RunFiredFunctionItem *AddRunFiredFunctionToCallList(
+  Environment *theEnv,
+  const char *name,
+  int priority,
+  RunFiredFunction *func,
+  RunFiredFunctionItem *head,
+  void *context)
+  {
+   RunFiredFunctionItem *newPtr, *currentPtr, *lastPtr = NULL;
+   char *nameCopy;
+
+   newPtr = get_struct(theEnv,runFiredFunctionItem);
+
+   nameCopy = (char *) genalloc(theEnv,strlen(name) + 1);
+   genstrcpy(nameCopy,name);
+   newPtr->name = nameCopy;
+
+   newPtr->func = func;
+   newPtr->priority = priority;
+   newPtr->context = context;
+
+   if (head == NULL)
+     {
+      newPtr->next = NULL;
+      return newPtr;
+     }
+
+   currentPtr = head;
+   while ((currentPtr != NULL) ? (priority < currentPtr->priority) : false)
+     {
+      lastPtr = currentPtr;
+      currentPtr = currentPtr->next;
+     }
+
+   if (lastPtr == NULL)
+     {
+      newPtr->next = head;
+      head = newPtr;
+     }
+   else
+     {
+      newPtr->next = currentPtr;
+      lastPtr->next = newPtr;
+     }
+
+   return head;
+  }
+
+/***********************************************************/
+/* RemoveRunFiredFunctionFromCallList: Removes a function */
+/*   from a run fired function list.                      */
+/***********************************************************/
+RunFiredFunctionItem *RemoveRunFiredFunctionFromCallList(
+  Environment *theEnv,
+  const char *name,
+  RunFiredFunctionItem *head,
+  bool *found)
+  {
+   RunFiredFunctionItem *currentPtr, *lastPtr;
+
+   *found = false;
+   lastPtr = NULL;
+   currentPtr = head;
+
+   while (currentPtr != NULL)
+     {
+      if (strcmp(name,currentPtr->name) == 0)
+        {
+         *found = true;
+         if (lastPtr == NULL)
+           { head = currentPtr->next; }
+         else
+           { lastPtr->next = currentPtr->next; }
+
+         genfree(theEnv,(void *) currentPtr->name,strlen(currentPtr->name) + 1);
+         rtn_struct(theEnv,runFiredFunctionItem,currentPtr);
          return head;
         }
 
@@ -1148,6 +1321,26 @@ void DeallocateRuleFiredCallList(
      }
   }
 
+/*****************************************************/
+/* DeallocateRunFiredCallList: Removes all functions */
+/*   from a list of run fired functions.             */
+/*****************************************************/
+void DeallocateRunFiredCallList(
+  Environment *theEnv,
+  RunFiredFunctionItem *theList)
+  {
+   RunFiredFunctionItem *tmpPtr, *nextPtr;
+
+   tmpPtr = theList;
+   while (tmpPtr != NULL)
+     {
+      nextPtr = tmpPtr->next;
+      genfree(theEnv,(void *) tmpPtr->name,strlen(tmpPtr->name) + 1);
+      rtn_struct(theEnv,runFiredFunctionItem,tmpPtr);
+      tmpPtr = nextPtr;
+     }
+  }
+
 /*******************************************************/
 /* RunCommand: H/L access routine for the run command. */
 /*******************************************************/
