                                                                RuleFiredFunctionItem *,bool *);
+
+   bool                    AddAfterRunFiresFunction(Environment *,const char *,
+                                                    RunFiredFunction *,int,void *);
+   bool                    RemoveAfterRunFiresFunction(Environment *,const char *);
+   bool                    AddBeforeRunFiresFunction(Environment *,const char *,
+                                                     RunFiredFunction *,int,void *);
+   bool                    RemoveBeforeRunFiresFunction(Environment *,const char *);
+   RunFiredFunctionItem   *AddRunFiredFunctionToCallList(Environment *,const char *,int,RunFiredFunction *,
+                                                          RunFiredFunctionItem *,void *);
+   RunFiredFunctionItem   *RemoveRunFiredFunctionFromCallList(Environment *,const char *,
+                                                               RunFiredFunctionItem *,bool *);
+
    void                    DeallocateRuleFiredCallList(Environment *,RuleFiredFunctionItem *);
+   void                    DeallocateRunFiredCallList(Environment *,RunFiredFunctionItem *);
    void                    InitializeEngine(Environment *);
    void                    SetBreak(Defrule *);
    void                    Halt(Environment *);
