+
    /*=====================================================*/
    /* Fire rules until the agenda is empty, the run limit */
    /* has been reached, or a rule execution error occurs. */
@@ -550,17 +563,15 @@ long long Run(
         }
      }
 
-   /*=====================================================*/
-   /* Make sure run functions are executed at least once. */
-   /*=====================================================*/
