+
+   for (deftemplateCallbackFunction = DeftemplateData(theEnv)->ListOfDeftemplateAssertFunctions;
+        deftemplateCallbackFunction != NULL;
+        deftemplateCallbackFunction = deftemplateCallbackFunction->next)
+     {
+      (*deftemplateCallbackFunction->func)(theEnv,newDeftemplate,deftemplateCallbackFunction->context);
+     }
+
 #else
 #if MAC_XCD
 #pragma unused(theEnv)
