@@ -100,6 +100,7 @@ bool ParseDeftemplate(
 #if (! RUN_TIME) && (! BLOAD_ONLY)
    CLIPSLexeme *deftemplateName;
    Deftemplate *newDeftemplate;
+   DeftemplateCallbackFunctionItem *deftemplateCallbackFunction;
    struct templateSlot *slots;
    struct token inputToken;
 
@@ -222,6 +223,17 @@ bool ParseDeftemplate(
 
    InstallDeftemplate(theEnv,newDeftemplate);
 
+   /*=====================================*/
