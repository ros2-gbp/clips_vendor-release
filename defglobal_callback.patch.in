    /* If the new value passed for the defglobal is NULL, */
    /* then reset the defglobal to the initial value it   */
@@ -507,6 +511,14 @@ void QSetDefglobalValue(
 
    theGlobal->current.value = newValue.value;
 
+   /*=================================*/
+   /* Call defglobal assert function. */
+   /*=================================*/
+   for (defglobalAssertFunction = DefglobalData(theEnv)->ListOfDefglobalAssertFunctions;
+         defglobalAssertFunction != NULL;
+         defglobalAssertFunction = defglobalAssertFunction->next)
+     { (*defglobalAssertFunction->func)(theEnv,theGlobal,defglobalAssertFunction->context); }
+
    /*===========================================*/
    /* Set the variable indicating that a change */
    /* has been made to a global variable.       */
@@ -1038,6 +1050,184 @@ Defglobal *GetNextDefglobalInScope(
    return NULL;
   }
 
+/***********************************************/
+/* AddDefglobalAssertFunction: Adds a function */
+/*   to the ListOfDefglobalAssertFunctions.    */
+/***********************************************/
+bool AddDefglobalAssertFunction(
+  Environment *theEnv,
+  const char *name,
+  DefglobalCallbackFunction *functionPtr,
+  int priority,
+  void *context)
+  {
+   DefglobalData(theEnv)->ListOfDefglobalAssertFunctions =
+      AddDefglobalCallbackFunctionToCallList(theEnv,name,priority,functionPtr,
+                                            DefglobalData(theEnv)->ListOfDefglobalAssertFunctions,context);
+   return true;
+  }
+
+/****************************************************/
+/* RemoveDefglobalAssertFunction: Removes a function */
+/*   from the ListOfDefglobalAssertFunctions.       */
+/****************************************************/
+bool RemoveDefglobalAssertFunction(
+  Environment *theEnv,
+  const char *name)
+  {
+   bool found;
+
+   DefglobalData(theEnv)->ListOfDefglobalAssertFunctions =
+      RemoveDefglobalCallbackFunctionFromCallList(theEnv,name,
+                                                 DefglobalData(theEnv)->ListOfDefglobalAssertFunctions,&found);
+
+   return found;
+  }
+
+/************************************************/
+/* AddDefglobalRetractFunction: Adds a function */
+/*   to the ListOfDefglobalRetractFunctions.    */
+/************************************************/
+bool AddDefglobalRetractFunction(
+  Environment *theEnv,
+  const char *name,
+  DefglobalCallbackFunction *functionPtr,
+  int priority,
+  void *context)
+  {
+   DefglobalData(theEnv)->ListOfDefglobalRetractFunctions =
+      AddDefglobalCallbackFunctionToCallList(theEnv,name,priority,functionPtr,
+                                            DefglobalData(theEnv)->ListOfDefglobalRetractFunctions,context);
+   return true;
+  }
+
+/****************************************************/
+/* RemoveDefglobalRetractFunction: Removes a function */
+/*   from the ListOfDefglobalAssertFunctions.       */
+/****************************************************/
+bool RemoveDefglobalRetractFunction(
+  Environment *theEnv,
+  const char *name)
+  {
+   bool found;
+
+   DefglobalData(theEnv)->ListOfDefglobalRetractFunctions =
+      RemoveDefglobalCallbackFunctionFromCallList(theEnv,name,
+                                                 DefglobalData(theEnv)->ListOfDefglobalRetractFunctions,&found);
+
+   return found;
+  }
+
+/***********************************************************/
+/* AddDefglobalCallbackFunctionToCallList: Adds a function */
+/*   to a defglobal changed function list.                 */
+/***********************************************************/
+DefglobalCallbackFunctionItem *AddDefglobalCallbackFunctionToCallList(
+  Environment *theEnv,
+  const char *name,
+  int priority,
+  DefglobalCallbackFunction *func,
+  DefglobalCallbackFunctionItem *head,
+  void *context)
+  {
+   DefglobalCallbackFunctionItem *newPtr, *currentPtr, *lastPtr = NULL;
+   char *nameCopy;
+
+   newPtr = get_struct(theEnv,defglobalCallbackFunctionItem);
+
+   nameCopy = (char *) genalloc(theEnv,strlen(name) + 1);
+   genstrcpy(nameCopy,name);
+   newPtr->name = nameCopy;
+
+   newPtr->func = func;
+   newPtr->priority = priority;
+   newPtr->context = context;
+
+   if (head == NULL)
+     {
+      newPtr->next = NULL;
+      return newPtr;
+     }
+
+   currentPtr = head;
+   while ((currentPtr != NULL) ? (priority < currentPtr->priority) : false)
+     {
+      lastPtr = currentPtr;
+      currentPtr = currentPtr->next;
+     }
+
+   if (lastPtr == NULL)
+     {
+      newPtr->next = head;
+      head = newPtr;
+     }
+   else
+     {
+      newPtr->next = currentPtr;
+      lastPtr->next = newPtr;
+     }
+
+   return head;
+  }
+
+/*******************************************************************/
+/* RemoveDefglobalCallbackFunctionFromCallList: Removes a function */
+/*   from a defglobal changed function list.                       */
+/*******************************************************************/
+DefglobalCallbackFunctionItem *RemoveDefglobalCallbackFunctionFromCallList(
+  Environment *theEnv,
+  const char *name,
+  DefglobalCallbackFunctionItem *head,
+  bool *found)
+  {
+   DefglobalCallbackFunctionItem *currentPtr, *lastPtr;
+
+   *found = false;
+   lastPtr = NULL;
+   currentPtr = head;
+
+   while (currentPtr != NULL)
+     {
+      if (strcmp(name,currentPtr->name) == 0)
+        {
+         *found = true;
+         if (lastPtr == NULL)
+           { head = currentPtr->next; }
+         else
+           { lastPtr->next = currentPtr->next; }
+
+         genfree(theEnv,(void *) currentPtr->name,strlen(currentPtr->name) + 1);
+         rtn_struct(theEnv,defglobalCallbackFunctionItem,currentPtr);
+         return head;
+        }
+
+      lastPtr = currentPtr;
+      currentPtr = currentPtr->next;
+     }
+
+   return head;
+  }
+
+/************************************************************/
+/* DeallocateDefglobalCallbackFunctionCallList: Removes all */
+/*   functions from a list of defglobal changed functions.  */
+/************************************************************/
+void DeallocateDefglobalCallbackFunctionCallList(
+  Environment *theEnv,
+  DefglobalCallbackFunctionItem *theList)
+  {
+   DefglobalCallbackFunctionItem *tmpPtr, *nextPtr;
+
+   tmpPtr = theList;
+   while (tmpPtr != NULL)
+     {
+      nextPtr = tmpPtr->next;
+      genfree(theEnv,(void *) tmpPtr->name,strlen(tmpPtr->name) + 1);
+      rtn_struct(theEnv,defglobalCallbackFunctionItem,tmpPtr);
+      tmpPtr = nextPtr;
+     }
+  }
+
 #if RUN_TIME
 
 /************************************************/
diff --git a/@CLIPS_SOURCE@/branches/@BRANCH@/core/globldef.h b/@CLIPS_SOURCE@/branches/@BRANCH@/core/globldef.h
--- a/@CLIPS_SOURCE@/branches/@BRANCH@/core/globldef.h
+++ b/@CLIPS_SOURCE@/branches/@BRANCH@/core/globldef.h
@@ -75,6 +75,18 @@ typedef struct defglobal Defglobal;
 
 #define DEFGLOBAL_DATA 1
 
+typedef struct defglobalCallbackFunctionItem DefglobalCallbackFunctionItem;
+typedef void DefglobalCallbackFunction(Environment *,Defglobal *,void *);
+
+struct defglobalCallbackFunctionItem
+  {
+   const char *name;
+   DefglobalCallbackFunction *func;
+   int priority;
+   DefglobalCallbackFunctionItem *next;
+   void *context;
+  };
+
 struct defglobalData
   {
    Construct *DefglobalConstruct;
@@ -91,6 +103,8 @@ struct defglobalData
 #if CONSTRUCT_COMPILER && (! RUN_TIME)
    struct CodeGeneratorItem *DefglobalCodeItem;
 #endif
+   DefglobalCallbackFunctionItem *ListOfDefglobalAssertFunctions;
+   DefglobalCallbackFunctionItem *ListOfDefglobalRetractFunctions;
   };
 
 struct defglobal
@@ -142,6 +156,17 @@ struct defglobalModule
    const char                    *DefglobalModule(Defglobal *);
    const char                    *DefglobalName(Defglobal *);
    const char                    *DefglobalPPForm(Defglobal *);
+
+   bool                           AddDefglobalAssertFunction(Environment *,const char *,DefglobalCallbackFunction *,int,void *);
+   bool                           RemoveDefglobalAssertFunction(Environment *,const char *);
+   bool                           AddDefglobalRetractFunction(Environment *,const char *,DefglobalCallbackFunction *,int,void *);
+   bool                           RemoveDefglobalRetractFunction(Environment *,const char *);
+   DefglobalCallbackFunctionItem *AddDefglobalCallbackFunctionToCallList(Environment *,const char *,int,DefglobalCallbackFunction *,
+                                                                        DefglobalCallbackFunctionItem *,void *);
+   DefglobalCallbackFunctionItem *RemoveDefglobalCallbackFunctionFromCallList(Environment *,const char *,
+                                                                             DefglobalCallbackFunctionItem *,bool *);
+   void                           DeallocateDefglobalCallbackFunctionCallList(Environment *,DefglobalCallbackFunctionItem *);
+
 #if RUN_TIME
    void                           DefglobalRunTimeInitialize(Environment *);
 #endif
