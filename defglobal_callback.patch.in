--- a/@CLIPS_SOURCE@/branches/@BRANCH@/core/globlbsc.c
+++ b/@CLIPS_SOURCE@/branches/@BRANCH@/core/globlbsc.c
@@ -189,15 +189,24 @@ bool Undefglobal(
   Environment *allEnv)
   {
    Environment *theEnv;
-   
+   DefglobalCallbackFunctionItem *defglobalRetractFunction;
+
    if (theDefglobal == NULL)
      {
       theEnv = allEnv;
       return(Undefconstruct(theEnv,NULL,DefglobalData(theEnv)->DefglobalConstruct));
      }
-   else 
+   else
      {
       theEnv = theDefglobal->header.env;
+
+      /*=================================*/
+      /* Call defglobal change function. */
+      /*=================================*/
+      for (defglobalRetractFunction = DefglobalData(theEnv)->ListOfDefglobalRetractFunctions;
+            defglobalRetractFunction != NULL;
+            defglobalRetractFunction = defglobalRetractFunction->next)
+        { (*defglobalRetractFunction->func)(theEnv,theDefglobal,defglobalRetractFunction->context); }
       return(Undefconstruct(theEnv,&theDefglobal->header,DefglobalData(theEnv)->DefglobalConstruct));
      }
   }
diff --git a/@CLIPS_SOURCE@/branches/@BRANCH@/core/globldef.c b/@CLIPS_SOURCE@/branches/@BRANCH@/core/globldef.c
