@@ -85,6 +85,9 @@ typedef struct construct Construct;
 typedef void SaveCallFunction(Environment *,Defmodule *,const char *,void *);
 typedef struct saveCallFunctionItem SaveCallFunctionItem;
 
+typedef void RedefineCallbackFunction(Environment *,const char *,const char *,const char *,void *);
+typedef struct redefineCallbackFunctionItem RedefineCallbackFunctionItem;
+
 typedef void ParserErrorFunction(Environment *,const char *,const char *,const char *,long,void *);
 typedef bool BeforeResetFunction(Environment *);
 
@@ -99,6 +102,15 @@ struct saveCallFunctionItem
    void *context;
   };
 
+struct redefineCallbackFunctionItem
+  {
+   const char *name;
+   RedefineCallbackFunction *func;
+   int priority;
+   struct redefineCallbackFunctionItem *next;
+   void *context;
+  };
+
 struct construct
   {
    const char *constructName;
@@ -124,10 +136,12 @@ struct constructData
    bool ClearInProgress;
    bool ResetReadyInProgress;
    bool ResetInProgress;
+   bool RedefineInProgress;
    short ClearReadyLocks;
    int DanglingConstructs;
 #if (! RUN_TIME) && (! BLOAD_ONLY)
    SaveCallFunctionItem *ListOfSaveFunctions;
+   RedefineCallbackFunctionItem *ListOfRedefineFunctions;
    bool PrintWhileLoading;
    bool LoadInProgress;
    bool WatchCompilations;
@@ -169,6 +183,11 @@ struct constructData
    bool                           RemoveClearReadyFunction(Environment *,const char *);
    bool                           AddClearFunction(Environment *,const char *,VoidCallFunction *,int,void *);
    bool                           RemoveClearFunction(Environment *,const char *);
+
+   bool                           AddRedefineCallbackFunction(Environment *,const char *,
+                                                              RedefineCallbackFunction *,int,void *);
+   bool                           RemoveRedefineCallbackFunction(Environment *,const char *);
+
    void                           IncrementClearReadyLocks(Environment *);
    void                           DecrementClearReadyLocks(Environment *);
    Construct                     *AddConstruct(Environment *,const char *,const char *,
@@ -207,7 +226,12 @@ struct constructData
                                                             SaveCallFunction *,SaveCallFunctionItem *,void *);
    SaveCallFunctionItem          *RemoveSaveFunctionFromCallList(Environment *,const char *,
                                                                  SaveCallFunctionItem *,bool *);
+   RedefineCallbackFunctionItem  *AddRedefineFunctionToCallList(Environment *,const char *,int,
+                                                                RedefineCallbackFunction *,RedefineCallbackFunctionItem *,void *);
+   RedefineCallbackFunctionItem  *RemoveRedefineFunctionFromCallList(Environment *,const char *,
+                                                                     RedefineCallbackFunctionItem *,bool *);
    void                           DeallocateSaveCallList(Environment *,SaveCallFunctionItem *);
+   void                           DeallocateRedefineCallList(Environment *,RedefineCallbackFunctionItem *);
 
 #endif /* _H_constrct */
 
diff --git a/@CLIPS_SOURCE@/branches/@BRANCH@/core/modulutl.c b/@CLIPS_SOURCE@/branches/@BRANCH@/core/modulutl.c
