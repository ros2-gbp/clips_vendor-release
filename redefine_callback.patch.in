diff --git a/@CLIPS_SOURCE@/branches/@BRANCH@/core/constrct.c b/@CLIPS_SOURCE@/branches/@BRANCH@/core/constrct.c
--- a/@CLIPS_SOURCE@/branches/@BRANCH@/core/constrct.c
+++ b/@CLIPS_SOURCE@/branches/@BRANCH@/core/constrct.c
@@ -142,6 +142,8 @@ static void DeallocateConstructData(
    DeallocateVoidCallList(theEnv,ConstructData(theEnv)->ListOfResetFunctions);
    DeallocateVoidCallList(theEnv,ConstructData(theEnv)->ListOfClearFunctions);
    DeallocateBoolCallList(theEnv,ConstructData(theEnv)->ListOfClearReadyFunctions);
+   DeallocateRedefineCallList(theEnv,ConstructData(theEnv)->ListOfRedefineFunctions);
+
 
 #if (! RUN_TIME) && (! BLOAD_ONLY)
    if (ConstructData(theEnv)->ErrorString != NULL)
@@ -826,6 +828,151 @@ bool RemoveClearFunction(
    return false;
   }
 
+/******************************************************/
+/* AddRedefineCallbackFunction: Adds a function to    */
+/*   ListOfRedefineFunctions.                         */
+/******************************************************/
+bool AddRedefineCallbackFunction(
+  Environment *theEnv,
+  const char *name,
+  RedefineCallbackFunction *functionPtr,
+  int priority,
+  void *context)
+  {
+   ConstructData(theEnv)->ListOfRedefineFunctions =
+      AddRedefineFunctionToCallList(theEnv,name,priority,functionPtr,
+                                    ConstructData(theEnv)->ListOfRedefineFunctions,
+                                    context);
+   return true;
+  }
+
+/**************************************************************/
+/* RemoveRedefineCallbackFunction: Removes a function from    */
+/*   ListOfRedefineFunctions.                                 */
+/**************************************************************/
+bool RemoveRedefineCallbackFunction(
+  Environment *theEnv,
+  const char *name)
+  {
+   bool found;
+
+   ConstructData(theEnv)->ListOfRedefineFunctions =
+      RemoveRedefineFunctionFromCallList(theEnv,name,
+                                         ConstructData(theEnv)->ListOfRedefineFunctions,
+                                         &found);
+   return found;
+  }
+
+/***************************************************************/
+/* AddRedefineFunctionToCallList: Adds a function to a        */
+/*   list of construct redefinition callback functions.       */
+/***************************************************************/
+RedefineCallbackFunctionItem *AddRedefineFunctionToCallList(
+  Environment *theEnv,
+  const char *name,
+  int priority,
+  RedefineCallbackFunction *func,
+  RedefineCallbackFunctionItem *head,
+  void *context)
+  {
+   RedefineCallbackFunctionItem *newPtr, *currentPtr, *lastPtr = NULL;
+   char *nameCopy;
+
+   newPtr = get_struct(theEnv,redefineCallbackFunctionItem);
+
+   nameCopy = (char *) genalloc(theEnv,strlen(name) + 1);
+   genstrcpy(nameCopy,name);
+   newPtr->name = nameCopy;
+
+   newPtr->func = func;
+   newPtr->priority = priority;
+   newPtr->context = context;
+
+   if (head == NULL)
+     {
+      newPtr->next = NULL;
+      return newPtr;
+     }
+
+   currentPtr = head;
+   while ((currentPtr != NULL) ? (priority < currentPtr->priority) : false)
+     {
+      lastPtr = currentPtr;
+      currentPtr = currentPtr->next;
+     }
+
+   if (lastPtr == NULL)
+     {
+      newPtr->next = head;
+      head = newPtr;
+     }
+   else
+     {
+      newPtr->next = currentPtr;
+      lastPtr->next = newPtr;
+     }
+
+   return head;
+  }
+
+/******************************************************************/
+/* RemoveRedefineFunctionFromCallList: Removes a function         */
+/*   from a construct redefinition callback function list.        */
+/******************************************************************/
+RedefineCallbackFunctionItem *RemoveRedefineFunctionFromCallList(
+  Environment *theEnv,
+  const char *name,
+  RedefineCallbackFunctionItem *head,
+  bool *found)
+  {
+   RedefineCallbackFunctionItem *currentPtr, *lastPtr;
+
+   *found = false;
+   lastPtr = NULL;
+   currentPtr = head;
+
+   while (currentPtr != NULL)
+     {
+      if (strcmp(name,currentPtr->name) == 0)
+        {
+         *found = true;
+         if (lastPtr == NULL)
+           { head = currentPtr->next; }
+         else
+           { lastPtr->next = currentPtr->next; }
+
+         genfree(theEnv,(void *) currentPtr->name,strlen(currentPtr->name) + 1);
+         rtn_struct(theEnv,redefineCallbackFunctionItem,currentPtr);
+         return head;
+        }
+
+      lastPtr = currentPtr;
+      currentPtr = currentPtr->next;
+     }
+
+   return head;
+  }
+
+/***************************************************************/
+/* DeallocateRedefineCallList: Removes all functions from     */
+/*   a list of construct redefinition callback functions.     */
+/***************************************************************/
+void DeallocateRedefineCallList(
+  Environment *theEnv,
+  RedefineCallbackFunctionItem *theList)
+  {
+   RedefineCallbackFunctionItem *tmpPtr, *nextPtr;
+
+   tmpPtr = theList;
+   while (tmpPtr != NULL)
+     {
+      nextPtr = tmpPtr->next;
+      genfree(theEnv,(void *) tmpPtr->name,strlen(tmpPtr->name) + 1);
+      rtn_struct(theEnv,redefineCallbackFunctionItem,tmpPtr);
+      tmpPtr = nextPtr;
+     }
+  }
+
 /********************************************/
 /* ExecutingConstruct: Returns true if a    */
 /*   construct is currently being executed, */
diff --git a/@CLIPS_SOURCE@/branches/@BRANCH@/core/constrct.h b/@CLIPS_SOURCE@/branches/@BRANCH@/core/constrct.h
--- a/@CLIPS_SOURCE@/branches/@BRANCH@/core/constrct.h
