@@ -848,6 +848,8 @@ CLIPSLexeme *GetConstructNameAndComment(
    ConstructHeader *theConstruct;
    unsigned separatorPosition;
    Defmodule *theModule;
+   bool rv;
+   RedefineCallbackFunctionItem *redefineCallbackFunction;
 
    /*==========================*/
    /* Next token should be the */
@@ -951,7 +953,10 @@ CLIPSLexeme *GetConstructNameAndComment(
          if (deleteFunction != NULL)
            {
             RetainLexeme(theEnv,name);
-            if ((*deleteFunction)(theConstruct,theEnv) == false)
+            ConstructData(theEnv)->RedefineInProgress = true;
+            rv = (*deleteFunction)(theConstruct,theEnv);
+            ConstructData(theEnv)->RedefineInProgress = false;
+            if (rv == false)
               {
                PrintErrorID(theEnv,"CSTRCPSR",4,true);
                WriteString(theEnv,STDERR,"Cannot redefine ");
@@ -967,6 +972,22 @@ CLIPSLexeme *GetConstructNameAndComment(
         }
      }
 
+   if (redefining)
+     {
+      /*====================================*/
+      /* Call redefine callback functions.  */
+      /*====================================*/
+
+      for (redefineCallbackFunction = ConstructData(theEnv)->ListOfRedefineFunctions;
+           redefineCallbackFunction != NULL;
+           redefineCallbackFunction = redefineCallbackFunction->next)
+        {
+         (*redefineCallbackFunction->func)(theEnv,constructName,
+                                           DefmoduleName(theModule),
+                                           name->contents,
+                                           redefineCallbackFunction->context);
+        }
+     }
    /*=============================================*/
    /* If compilations are being watched, indicate */
    /* that a construct is being compiled.         */
