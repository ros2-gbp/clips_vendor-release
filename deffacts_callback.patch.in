diff --git a/@CLIPS_SOURCE@/branches/@BRANCH@/core/dffctbsc.c b/@CLIPS_SOURCE@/branches/@BRANCH@/core/dffctbsc.c
--- a/@CLIPS_SOURCE@/branches/@BRANCH@/core/dffctbsc.c
