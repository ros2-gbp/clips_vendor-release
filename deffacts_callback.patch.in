+
+struct deffactsCallbackFunctionItem
+  {
+   const char *name;
+   DeffactsCallbackFunction *func;
+   int priority;
+   DeffactsCallbackFunctionItem *next;
+   void *context;
+  };
+
 #include "constrct.h"
 #include "conscomp.h"
 #include "cstrccom.h"
