+            (*deffactsCallbackFunction->func)(theEnv,theDeffacts,deffactsCallbackFunction->context);
+           }
+        }
       return Undefconstruct(theEnv,&theDeffacts->header,DeffactsData(theEnv)->DeffactsConstruct);
      }
   }
diff --git a/@CLIPS_SOURCE@/branches/@BRANCH@/core/dffctdef.c b/@CLIPS_SOURCE@/branches/@BRANCH@/core/dffctdef.c
--- a/@CLIPS_SOURCE@/branches/@BRANCH@/core/dffctdef.c
