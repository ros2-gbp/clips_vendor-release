@@ -123,6 +123,8 @@ static void DeallocateDeffactsData(
 #if BLOAD || BLOAD_AND_BSAVE
    if (Bloaded(theEnv)) return;
 #endif
+   DeallocateDeffactsCallbackFunctionCallList(theEnv,DeffactsData(theEnv)->ListOfDeffactsAssertFunctions);
+   DeallocateDeffactsCallbackFunctionCallList(theEnv,DeffactsData(theEnv)->ListOfDeffactsRetractFunctions);
 
    DoForAllConstructs(theEnv,
                       DestroyDeffactsAction,
@@ -358,6 +360,185 @@ const char *DeffactsPPForm(
    return GetConstructPPForm(&theDeffacts->header);
   }
 
+/**********************************************/
+/* AddDeffactsAssertFunction: Adds a function */
+/*   to the ListOfDeffactsAssertFunctions.    */
+/**********************************************/
+bool AddDeffactsAssertFunction(
+  Environment *theEnv,
+  const char *name,
+  DeffactsCallbackFunction *functionPtr,
+  int priority,
+  void *context)
+  {
+   DeffactsData(theEnv)->ListOfDeffactsAssertFunctions =
+      AddDeffactsCallbackFunctionToCallList(theEnv,name,priority,functionPtr,
+                                            DeffactsData(theEnv)->ListOfDeffactsAssertFunctions,context);
+
+   return true;
+  }
+
+/***************************************************/
+/* RemoveDeffactsAssertFunction: Removes a function */
+/*   from the ListOfDeffactsAssertFunctions.        */
+/***************************************************/
+bool RemoveDeffactsAssertFunction(
+  Environment *theEnv,
+  const char *name)
+  {
+   bool found;
+
+   DeffactsData(theEnv)->ListOfDeffactsAssertFunctions =
+      RemoveDeffactsCallbackFunctionFromCallList(theEnv,name,
+                                                 DeffactsData(theEnv)->ListOfDeffactsAssertFunctions,&found);
+
+   return found;
+  }
+
+/***********************************************/
+/* AddDeffactsRetractFunction: Adds a function */
+/*   to the ListOfDeffactsRetractFunctions.    */
+/***********************************************/
+bool AddDeffactsRetractFunction(
+  Environment *theEnv,
+  const char *name,
+  DeffactsCallbackFunction *functionPtr,
+  int priority,
+  void *context)
+  {
+   DeffactsData(theEnv)->ListOfDeffactsRetractFunctions =
+      AddDeffactsCallbackFunctionToCallList(theEnv,name,priority,functionPtr,
+                                            DeffactsData(theEnv)->ListOfDeffactsRetractFunctions,context);
+
+   return true;
+  }
+
+/****************************************************/
+/* RemoveDeffactsRetractFunction: Removes a function */
+/*   from the ListOfDeffactsRetractFunctions.        */
+/****************************************************/
+bool RemoveDeffactsRetractFunction(
+  Environment *theEnv,
+  const char *name)
+  {
+   bool found;
+
+   DeffactsData(theEnv)->ListOfDeffactsRetractFunctions =
+      RemoveDeffactsCallbackFunctionFromCallList(theEnv,name,
+                                                 DeffactsData(theEnv)->ListOfDeffactsRetractFunctions,&found);
+
+   return found;
+  }
+
+/*********************************************************/
+/* AddDeffactsCallbackFunctionToCallList: Adds a function */
+/*   to a deffacts callback function list.                */
+/*********************************************************/
+DeffactsCallbackFunctionItem *AddDeffactsCallbackFunctionToCallList(
+  Environment *theEnv,
+  const char *name,
+  int priority,
+  DeffactsCallbackFunction *func,
+  DeffactsCallbackFunctionItem *head,
+  void *context)
+  {
+   DeffactsCallbackFunctionItem *newPtr, *currentPtr, *lastPtr = NULL;
+   char *nameCopy;
+
+   newPtr = get_struct(theEnv,deffactsCallbackFunctionItem);
+
+   nameCopy = (char *) genalloc(theEnv,strlen(name) + 1);
+   genstrcpy(nameCopy,name);
+   newPtr->name = nameCopy;
+
+   newPtr->func = func;
+   newPtr->priority = priority;
+   newPtr->context = context;
+
+   if (head == NULL)
+     {
+      newPtr->next = NULL;
+      return newPtr;
+     }
+
+   currentPtr = head;
+   while ((currentPtr != NULL) ? (priority < currentPtr->priority) : false)
+     {
+      lastPtr = currentPtr;
+      currentPtr = currentPtr->next;
+     }
+
+   if (lastPtr == NULL)
+     {
+      newPtr->next = head;
+      head = newPtr;
+     }
+   else
+     {
+      newPtr->next = currentPtr;
+      lastPtr->next = newPtr;
+     }
+
+   return head;
+  }
+
+/*****************************************************************/
+/* RemoveDeffactsCallbackFunctionFromCallList: Removes a         */
+/*   function from a deffacts callback function list.            */
+/*****************************************************************/
+DeffactsCallbackFunctionItem *RemoveDeffactsCallbackFunctionFromCallList(
+  Environment *theEnv,
+  const char *name,
+  DeffactsCallbackFunctionItem *head,
+  bool *found)
+  {
+   DeffactsCallbackFunctionItem *currentPtr, *lastPtr;
+
+   *found = false;
+   lastPtr = NULL;
+   currentPtr = head;
+
+   while (currentPtr != NULL)
+     {
+      if (strcmp(name,currentPtr->name) == 0)
+        {
+         *found = true;
+         if (lastPtr == NULL)
+           { head = currentPtr->next; }
+         else
+           { lastPtr->next = currentPtr->next; }
+
+         genfree(theEnv,(void *) currentPtr->name,strlen(currentPtr->name) + 1);
+         rtn_struct(theEnv,deffactsCallbackFunctionItem,currentPtr);
+         return head;
+        }
+
+      lastPtr = currentPtr;
+      currentPtr = currentPtr->next;
+     }
+
+   return head;
+  }
+
+/***********************************************************/
+/* DeallocateDeffactsCallbackFunctionCallList: Removes all */
+/*   functions from a list of deffacts callback functions. */
+/***********************************************************/
+void DeallocateDeffactsCallbackFunctionCallList(
+  Environment *theEnv,
+  DeffactsCallbackFunctionItem *theList)
+  {
+   DeffactsCallbackFunctionItem *tmpPtr, *nextPtr;
+
+   tmpPtr = theList;
+   while (tmpPtr != NULL)
+     {
+      nextPtr = tmpPtr->next;
+      genfree(theEnv,(void *) tmpPtr->name,strlen(tmpPtr->name) + 1);
+      rtn_struct(theEnv,deffactsCallbackFunctionItem,tmpPtr);
+      tmpPtr = nextPtr;
+     }
+  }
 
 #endif /* DEFFACTS_CONSTRUCT */
 
