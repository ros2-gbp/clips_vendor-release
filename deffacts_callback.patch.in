@@ -198,7 +198,8 @@ bool Undeffacts(
   Environment *allEnv)
   {
    Environment *theEnv;
-   
+   DeffactsCallbackFunctionItem *deffactsCallbackFunction;
+
    if (theDeffacts == NULL)
      {
       theEnv = allEnv;
@@ -207,6 +208,19 @@ bool Undeffacts(
    else
      {
       theEnv = theDeffacts->header.env;
+      if (!ConstructData(theEnv)->RedefineInProgress)
+        {
+         /*===================================*/
+         /* Call deffacts retract functions.  */
+         /*===================================*/
+
+         for (deffactsCallbackFunction = DeffactsData(theEnv)->ListOfDeffactsRetractFunctions;
+              deffactsCallbackFunction != NULL;
+              deffactsCallbackFunction = deffactsCallbackFunction->next)
