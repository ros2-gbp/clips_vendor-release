 #if CONSTRUCT_COMPILER && (! RUN_TIME)
    struct CodeGeneratorItem *DeffactsCodeItem;
 #endif
+   DeffactsCallbackFunctionItem *ListOfDeffactsAssertFunctions;
+   DeffactsCallbackFunctionItem *ListOfDeffactsRetractFunctions;
   };
 
 struct deffacts
@@ -98,6 +112,17 @@ struct deffactsModule
 #if RUN_TIME
    void                           DeffactsRunTimeInitialize(Environment *);
 #endif
+   bool                           AddDeffactsAssertFunction(Environment *,const char *,
+                                                            DeffactsCallbackFunction *,int,void *);
+   bool                           RemoveDeffactsAssertFunction(Environment *,const char *);
+   bool                           AddDeffactsRetractFunction(Environment *,const char *,
+                                                             DeffactsCallbackFunction *,int,void *);
+   bool                           RemoveDeffactsRetractFunction(Environment *,const char *);
+   DeffactsCallbackFunctionItem  *AddDeffactsCallbackFunctionToCallList(Environment *,const char *,int,
+                                                                        DeffactsCallbackFunction *,DeffactsCallbackFunctionItem *,void *);
+   DeffactsCallbackFunctionItem  *RemoveDeffactsCallbackFunctionFromCallList(Environment *,const char *,
+                                                                             DeffactsCallbackFunctionItem *,bool *);
+   void                           DeallocateDeffactsCallbackFunctionCallList(Environment *,DeffactsCallbackFunctionItem *);
 
 #endif /* _H_dffctdef */
 
