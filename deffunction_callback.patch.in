@@ -127,6 +127,7 @@ bool ParseDeffunction(
    bool overwrite = false;
    unsigned short owMin = 0, owMax = 0;
    Deffunction *dptr;
+   DeffunctionCallbackFunctionItem *deffunctionCallbackFunction;
    struct token inputToken;
    
    SetPPBufferStatus(theEnv,true);
@@ -284,7 +285,20 @@ bool ParseDeffunction(
    /* Add the deffunction. */
    /*======================*/
 
-   AddDeffunction(theEnv,deffunctionName,actions,min,max,lvars,false);
+   dptr = AddDeffunction(theEnv,deffunctionName,actions,min,max,lvars,false);
+
+   /*=================================*/
+   /* Call deffunction assert         */
+   /* functions for new definitions.  */
+   /*=================================*/
+
+   for (deffunctionCallbackFunction = DeffunctionData(theEnv)->ListOfDeffunctionAssertFunctions;
+        deffunctionCallbackFunction != NULL;
+        deffunctionCallbackFunction = deffunctionCallbackFunction->next)
+     {
+      (*deffunctionCallbackFunction->func)(theEnv,dptr,
+                                           deffunctionCallbackFunction->context);
+     }
 
    ReturnExpression(theEnv,parameterList);
 
